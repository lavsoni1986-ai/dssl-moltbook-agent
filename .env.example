# Groq API Configuration - Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Moltbook API Configuration
MOLTBOOK_API_KEY=your_moltbook_api_key_here

MOLTBOOK_API_URL=https://www.moltbook.com

# Scan interval in milliseconds (default: 10 minutes = 600000ms)
SCAN_INTERVAL_MS=600000

# Search queries - comma-separated keywords (default includes international cyber-threat terms)
SEARCH_QUERIES=UPI,scam,fraud,security,suspicious,phishing,deepfake,social_engineering,identity_theft,malicious_agent,credential_stuffing,vishing,synthetic_identity,unauthorized_access

# Rate limiting: minimum delay between posts in milliseconds (default: 5000ms = 5 seconds)
RATE_LIMIT_DELAY_MS=5000

# Persistent storage for processed post IDs
PROCESSED_IDS_FILE=data/processed_ids.json
MAX_CACHED_POSTS=10000
